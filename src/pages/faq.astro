---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    q: "When do RSVPs close?",
    a: "[RSVP deadline to be confirmed — typically 6–8 weeks before the wedding. We'll update this once the date is locked in.] Please respond by the deadline so we can give an accurate headcount to our venue and caterer.",
  },
  {
    q: "What's the dress code?",
    a: "Garden Formal. Think flowy dresses, linen suits, and anything that photographs well outdoors. Parts of the ceremony may be outside, so consider your footwear. Please avoid white, ivory, and champagne.",
  },
  {
    q: "Is there parking at the venue?",
    a: "[Parking details to be confirmed. This will be updated once the venue is locked in.] If you plan to drink at the reception, we recommend arranging a rideshare — both Uber and Lyft operate in the Santa Barbara area.",
  },
  {
    q: "Are kids welcome?",
    a: "[To be confirmed once venue capacity and logistics are finalized. We'll update this clearly when we know.]",
  },
  {
    q: "Is it indoors or outdoors?",
    a: "[Venue TBD — details will be updated here. Santa Barbara in April is typically beautiful, with mild temperatures in the mid-60s to low 70s.]",
  },
  {
    q: "Is there an open bar?",
    a: "Yes. Full open bar at the reception: wine, beer, cocktails, and non-alcoholic options. Please drink responsibly and plan your ride home accordingly.",
  },
  {
    q: "Who do I contact with questions?",
    a: "[Point person name] is coordinating guest logistics. Reach them at [contact@example.com]. Please don't text or call the couple directly in the weeks leading up to the wedding — we want to actually be present for it.",
  },
  {
    q: "Can I bring a plus-one?",
    a: "Plus-ones are noted on your invitation. If yours says your name only, the invitation is for you specifically. If you have questions, reach out to [point person name].",
  },
];
---
<BaseLayout title="FAQ" description="Frequently asked questions about Jack and Jenna's wedding.">

  <div class="section section--wide">
    <h1 class="page-heading">FAQ</h1>
    <p class="faq-intro prose">
      Everything you probably want to know, answered before you have to ask.
    </p>

    <dl class="faq-list">
      {faqs.map((item, i) => (
        <div class="faq-item">
          <dt class="faq-q">
            <span class="faq-num display">{String(i + 1).padStart(2, "0")}</span>
            {item.q}
          </dt>
          <dd class="faq-a">{item.a}</dd>
        </div>
      ))}
    </dl>

    <div class="faq-more">
      <p>Something not covered here?</p>
      <p>
        Reach out to [point person] at
        <a href="mailto:contact@example.com">[contact@example.com]</a>.
      </p>
    </div>
  </div>

</BaseLayout>

<style>
.faq-intro {
  margin-bottom: var(--s-lg);
  color: oklch(from var(--charcoal) calc(l + 0.22) c h);
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  background: oklch(from var(--blush) l c h / 0.25);
  border: 1px solid oklch(from var(--blush) l c h / 0.25);
}

.faq-item {
  background: var(--cream);
  padding: var(--s-md);
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.6rem;
}

.faq-q {
  font-family: var(--font-display);
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  font-weight: 400;
  color: var(--accent);
  line-height: 1.25;
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
}

.faq-num {
  font-size: 0.85rem;
  color: oklch(from var(--blush) calc(l - 0.18) c h);
  flex-shrink: 0;
  letter-spacing: 0.02em;
  align-self: flex-start;
  padding-top: 0.1em;
}

.faq-a {
  font-size: 0.95rem;
  line-height: 1.65;
  color: oklch(from var(--charcoal) calc(l + 0.18) c h);
  padding-left: calc(0.85rem + 0.75rem); /* align under question text */
  max-width: 65ch;
}

.faq-more {
  margin-top: var(--s-lg);
  padding: var(--s-md);
  background: oklch(from var(--sage) l c h / 0.1);
  border: 1px solid oklch(from var(--sage) l c h / 0.3);
  font-size: 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.faq-more a {
  color: var(--accent);
  text-underline-offset: 3px;
}
</style>
